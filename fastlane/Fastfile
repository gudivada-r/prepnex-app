lane :release do
  # 1. Manual Keychain Setup (Bulletproof method for remote CI)
  keychain_name = "ios_build_keychain"
  keychain_password = "build_password"
  
  # Ensure we start fresh
  delete_keychain(name: keychain_name) if File.exist?("#{Dir.home}/Library/Keychains/#{keychain_name}-db")
  
  create_keychain(
    name: keychain_name,
    password: keychain_password,
    default_keychain: true,
    unlock: true,
    timeout: 0, # Never lock again during this session
    add_to_search_list: true
  )

  # 2. Create the API key
  key = app_store_connect_api_key(
    key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
    issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
    key_content: ENV["APP_STORE_CONNECT_KEY_CONTENT"],
    is_key_content_base64: false
  )

  # 3. Get Certificates and Profiles
  # cert will now install into our 'ios_build_keychain' automatically
  cert(api_key: key)
  sigh(
    api_key: key,
    app_identifier: "com.studentsuccess.navigator",
    team_id: ENV["APPLE_TEAM_ID"],
    force: true
  )

  # 4. Force settings at the project level
  update_code_signing_settings(
    use_automatic_signing: false,
    path: "frontend/ios/App/App.xcodeproj",
    bundle_identifier: "com.studentsuccess.navigator",
    code_sign_identity: "Apple Distribution",
    profile_uuid: ENV["SIGH_UUID"],
    team_id: ENV["APPLE_TEAM_ID"]
  )

  # 5. Build the App
  build_app(
    project: "frontend/ios/App/App.xcodeproj",
    scheme: "App",
    export_method: "app-store",
    output_directory: "output",
    output_name: "App.ipa",
    clean: false,
    xcargs: "DEVELOPMENT_TEAM=#{ENV['APPLE_TEAM_ID']} PROVISIONING_PROFILE_SPECIFIER=#{ENV['SIGH_UUID']} CODE_SIGN_STYLE=Manual -sdk iphoneos -destination 'generic/platform=iOS' ENABLE_BITCODE=NO"
  )

  # 6. Upload to TestFlight
  upload_to_testflight(api_key: key)
end
