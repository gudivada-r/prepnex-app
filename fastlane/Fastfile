lane :release do
  # 1. Manual Keychain Setup
  keychain_name = "ios_build_keychain"
  keychain_password = "build_password"
  keychain_path = File.expand_path("~/Library/Keychains/#{keychain_name}-db")

  delete_keychain(name: keychain_name) if File.exist?(keychain_path)

  create_keychain(
    name: keychain_name,
    password: keychain_password,
    default_keychain: true,
    unlock: true,
    timeout: 0,
    add_to_search_list: true
  )

  # 1.5 Install WWDR Certificates (Essential for Trust Chain)
  # CI environments often lack these, causing "Untrusted Certificate" errors during signing.
  sh("curl -f -o AppleWWDRCAG3.cer https://www.apple.com/certificateauthority/AppleWWDRCAG3.cer && security import AppleWWDRCAG3.cer -k #{keychain_path} -T /usr/bin/codesign")
  sh("curl -f -o AppleWWDRCAG6.cer https://www.apple.com/certificateauthority/AppleWWDRCAG6.cer && security import AppleWWDRCAG6.cer -k #{keychain_path} -T /usr/bin/codesign")

  # 2. Authenticate
  key = app_store_connect_api_key(
    key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
    issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
    key_content: ENV["APP_STORE_CONNECT_KEY_CONTENT"],
    is_key_content_base64: false
  )



  # 3. Cleanup Old Certs (Avoid Max Limit)
  puts "Automated Cleanup: Checking for certificates to revoke..."
  Spaceship::ConnectAPI::Certificate.all.each do |c|
    if c.certificate_type == "DISTRIBUTION" || c.certificate_type == "IOS_DISTRIBUTION"
      puts "Revoking old certificate: #{c.id} (#{c.name})"
      c.delete!
    end
  end

  # 4. Get Certificates (Explicit Keychain)
  cert(
    api_key: key,
    keychain_path: keychain_path,
    keychain_password: keychain_password
  )

  # 5. Get Profiles
  sigh(
    api_key: key,
    app_identifier: "com.studentsuccess.navigator",
    team_id: ENV["APPLE_TEAM_ID"],
    force: true
  )

  # 5. Fix Project Settings
  update_code_signing_settings(
    use_automatic_signing: false,
    targets: ["App"],
    build_configurations: ["Release"],
    path: "frontend/ios/App/App.xcodeproj",
    bundle_identifier: "com.studentsuccess.navigator",
    code_sign_identity: "Apple Distribution",
    profile_uuid: ENV["SIGH_UUID"],
    team_id: ENV["APPLE_TEAM_ID"]
  )
  
  # 5.1 (Removed sed hacks, relying on update_code_signing_settings)

  # 5.5 Allow codesign to access the keychain without prompt (Crucial for CI)
  sh("security set-key-partition-list -S apple-tool:,apple:,codesign: -s -k #{keychain_password} #{keychain_path}")

  # 5.6 Ensure unique build number (Timestamp based to avoid duplicates)
  # increment_build_number failed due to missing Project settings.
  # We override CURRENT_PROJECT_VERSION directly in build arguments instead.
  
  # 6. Build the App
  build_app(
    workspace: "frontend/ios/App/App.xcworkspace", # Use workspace for CocoaPods (Capacitor 6+)
    scheme: "App",
    export_method: "app-store",
    output_directory: "output",
    output_name: "App.ipa",
    clean: true,
    suppress_xcode_output: false, # Show full log for debugging Exit Code 65
    # derived_data_path: "derived_data", # Let Fastlane handle this
    # Don't pass PROVISIONING_PROFILE_SPECIFIER globally in xcargs, it breaks Pods!
    # TARGETED_DEVICE_FAMILY=1 forces iPhone Only
    # CURRENT_PROJECT_VERSION overrides the build number with timestamp
    xcargs: "-sdk iphoneos -destination 'generic/platform=iOS' ENABLE_BITCODE=NO TARGETED_DEVICE_FAMILY=1 CURRENT_PROJECT_VERSION=#{Time.now.to_i}",
    export_options: {
      signingStyle: "manual",
      compileBitcode: false,
      provisioningProfiles: {
        "com.studentsuccess.navigator" => ENV["SIGH_UUID"]
      }
    }
  )

  # 7. Upload to TestFlight
  upload_to_testflight(api_key: key)
end
