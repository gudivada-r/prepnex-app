lane :release do
  # 0. CI Setup (Configures keychain, timeouts, etc. automatically)
  setup_ci

  # 1. Authenticate
  key = app_store_connect_api_key(
    key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
    issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
    key_content: ENV["APP_STORE_CONNECT_KEY_CONTENT"],
    is_key_content_base64: false
  )

  # 1.1 Ensure App ID exists (Fix for clean accounts)
  produce(
    app_identifier: "com.studentsuccess.navigator",
    app_name: "StudentSuccess",
    language: "en-US",
    app_version: "1.0.0",
    sku: "studentsuccess_nav_001"
  )

  # 2. Cleanup Old Certs (Avoid Max Limit)
  puts "Automated Cleanup: Checking for certificates to revoke..."
  Spaceship::ConnectAPI::Certificate.all.each do |c|
    if c.certificate_type == "DISTRIBUTION" || c.certificate_type == "IOS_DISTRIBUTION"
      puts "Revoking old certificate: #{c.id} (#{c.name})"
      c.delete!
    end
  end

  # 3. Get Certificates (Stores in CI Keychain)
  cert(api_key: key)

  # 4. Get Profiles
  sigh(
    api_key: key,
    app_identifier: "com.studentsuccess.navigator",
    team_id: ENV["APPLE_TEAM_ID"],
    force: true
  )

  # 5. Fix Project Settings
  update_code_signing_settings(
    use_automatic_signing: false,
    path: "frontend/ios/App/App.xcodeproj",
    bundle_identifier: "com.studentsuccess.navigator",
    code_sign_identity: "Apple Distribution",
    profile_uuid: ENV["SIGH_UUID"],
    team_id: ENV["APPLE_TEAM_ID"]
  )

  # 6. Build the App
  build_app(
    project: "frontend/ios/App/App.xcodeproj",
    scheme: "App",
    export_method: "app-store",
    output_directory: "output",
    output_name: "App.ipa",
    clean: true,
    # derived_data_path: "derived_data", # Let Fastlane handle this
    xcargs: "DEVELOPMENT_TEAM=#{ENV['APPLE_TEAM_ID']} PROVISIONING_PROFILE_SPECIFIER=#{ENV['SIGH_UUID']} CODE_SIGN_STYLE=Manual -sdk iphoneos -destination 'generic/platform=iOS' ENABLE_BITCODE=NO",
    export_options: {
      compileBitcode: false,
      provisioningProfiles: {
        "com.studentsuccess.navigator" => ENV["SIGH_UUID"]
      }
    }
  )

  # 7. Upload to TestFlight
  upload_to_testflight(api_key: key)
end
